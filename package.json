{
  "name": "chaibuilder",
  "version": "1.0.0",
  "description": "ChaiBuilder — visual site builder for Next.js with Payload CMS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-chaistyles.mjs && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "node scripts/generate-chaistyles.mjs && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && node scripts/generate-chaistyles.mjs && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:chaistyles": "node scripts/generate-chaistyles.mjs",
    "generate:importmap": "cross-env NODE_OPTIONS=\"--no-deprecation\" payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=\"--no-deprecation\" payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=\"--no-deprecation\" payload",
    "seed": "cross-env NODE_OPTIONS=\"--no-deprecation --import ./seed/register-stubs.mjs\" tsx ./seed/index.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/plugin-seo": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "chaipro": "0.1.3",
    "tailwindcss": "^4.3.2",
    "cnfast": "^0.0.8",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.3.0",
    "glob": "^13.0.6",
    "graphql": "^16.8.1",
    "lexical": "0.41.0",
    "next": "16.2.9",
    "payload": "3.85.1",
    "penpal": "^7.0.6",
    "react": "19.2.6",
    "react-diff-view": "^3.3.3",
    "react-dom": "19.2.6",
    "server-only": "0.0.1",
    "sharp": "0.34.2",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/escape-html": "^1.0.2",
    "@types/glob": "^9.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.9",
    "jsdom": "28.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.59.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  }
}
